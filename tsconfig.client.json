{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./public/js",
    "rootDir": "./src/webapp/client",
    "strict": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/webapp/client/**/*"]
}
